# PostgreSQL — paste your Neon or Supabase connection string here
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT — generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-key-change-this

# Google Gemini — get your key from https://aistudio.google.com/
GOOGLE_API_KEY=your-google-api-key

# Optional overrides (defaults shown)
# GEMINI_EMBEDDING_MODEL=models/embedding-004
# GEMINI_GENERATION_MODEL=gemini-2.0-flash
# CHROMA_PERSIST_DIR=./chroma_db
# CHROMA_COLLECTION_NAME=startup_navigator
# RAG_TOP_K=5

# App settings
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
